{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "engine/**/*.ts",
    "providers/**/*.ts",
    "tools/**/*.ts",
    "edit/**/*.ts",
    "session/**/*.ts",
    "config/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
