{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyAgent",
  "version": "0.1.0",
  "identifier": "site.oh-my-terminal.myagent",
  "build": {
    "beforeDevCommand": "pnpm sidecar:build && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm sidecar:build && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyAgent",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
